{
  "name": "swf2lottie",
  "version": "0.8.0",
  "private": true,
  "description": "Deterministic SWF to Lottie converter for a strict subset of Flash vector timelines.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:static": "node --import tsx scripts/build-static.ts",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "preview": "node --import tsx src/server/dev-server.ts",
    "preview:static": "node --import tsx scripts/preview-static.ts",
    "test": "vitest run",
    "export:fixtures": "node --import tsx scripts/export-fixtures.ts",
    "export:fixture": "node --import tsx scripts/export-fixtures.ts",
    "export:fixtures:web": "node --import tsx scripts/export-fixtures-web.ts",
    "export:fixture:web": "node --import tsx scripts/export-fixtures-web.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "jpeg-js": "^0.4.4",
    "lottie-web": "^5.13.0",
    "pngjs": "^7.0.0"
  }
}
